# Supabase
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Server-side only — JANGAN diberi prefix NEXT_PUBLIC_, tidak boleh masuk bundle client.
# Dipakai di app/api/**/route.ts untuk operasi yang butuh bypass RLS (mis. create-user, verify-kode, tracking).
SUPABASE_SERVICE_ROLE_KEY=

# WhatsApp toko (dipakai oleh waLink())
NEXT_PUBLIC_WA_TOKO=

# Claude API (chat widget katalog publik)
ANTHROPIC_API_KEY=

# GPS Tracking Sopir (Traccar Client — protokol OsmAnd)
# Token statis yang harus dikirim Traccar Client sebagai query param ?token=
# pada tiap request ke /api/tracking. Berfungsi sebagai auth pengganti login,
# karena Traccar Client tidak mendukung session/cookie Supabase.
# Isi manual dengan string acak yang panjang & rahasia (server-side only).
TRACKING_TOKEN=

# Booking mandiri customer (spec 10) — signing secret untuk cookie JWT
# `booking_session` di app/api/booking-auth/*. Akun customer booking
# mandiri TIDAK PERNAH lewat Supabase Auth (lihat docs/spec/10-booking-mandiri.md
# §2) — ini secret TERPISAH, WAJIB beda dari secret lain mana pun.
# Isi manual dengan string acak panjang (mis. `openssl rand -base64 32`).
BOOKING_JWT_SECRET=
